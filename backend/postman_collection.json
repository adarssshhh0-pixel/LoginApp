{
  "info": {
    "name": "i-SOFTZONE EMS API",
    "description": "Complete API collection for Enterprise Management System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "token",   "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"pranay@isoftzone.com\",\"password\":\"123456\"}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Signup",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/signup",
            "body": {
              "mode": "raw",
              "raw": "{\"name\":\"Test User\",\"email\":\"test@test.com\",\"password\":\"123456\"}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/forgot-password",
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"pranay@isoftzone.com\"}",
              "options": { "raw": { "language": "json" } }
            }
          }
        }
      ]
    },
    {
      "name": "Employees",
      "item": [
        {
          "name": "Get All (with pagination)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/employees?page=1&limit=10&search=&sortBy=ep.id&order=DESC",
            "header": [{ "key": "Authorization", "value": "{{token}}" }]
          }
        },
        {
          "name": "Get One",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/employees/1",
            "header": [{ "key": "Authorization", "value": "{{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/health"
          }
        }
      ]
    }
  ]
}